{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VartaPack Rules",
  "description": "Advanced validation rules and mod conflict definitions.",
  "type": "object",
  "required": ["schema"],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "supportPolicyText": {
      "type": "string",
      "description": "Text shown to users about the support policy for modified instances."
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    },
    "conflicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/conflict" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "type", "modId"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["BLOCKED_MOD", "SOFT_BLOCKED_MOD", "REQUIRED_MOD", "RECOMMENDED_MOD", "SUSPICIOUS_MOD", "ALLOWED_EXTRA_MOD", "ENVIRONMENT_RULE", "FILE_RULE"]
        },
        "modId": { "type": "string" },
        "displayName": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "category": { "type": "string" },
        "reason": { "type": "string" },
        "fix": { "type": "string" },
        "versionRange": { "type": "string" },
        "blockContinue": { "type": "boolean" }
      }
    },
    "conflict": {
      "type": "object",
      "required": ["id", "modA", "modB"],
      "properties": {
        "id": { "type": "string" },
        "modA": { "type": "string" },
        "modB": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "reason": { "type": "string" },
        "fix": { "type": "string" },
        "versionRangeA": { "type": "string" },
        "versionRangeB": { "type": "string" }
      }
    }
  }
}
