{
    "schemaVersion": 1,
    "id": "vartapack",
    "version": "${version}",
    "name": "VartaPack",
    "description": "A support report and diagnostics tool for Minecraft modpack authors.",
    "authors": [
        "stromblex"
    ],
    "contact": {
        "homepage": "https://github.com/stromblex/VartaPack",
        "sources": "https://github.com/stromblex/VartaPack",
        "issues": "https://github.com/stromblex/VartaPack/issues"
    },
    "license": "MIT",
    "icon": "assets/vartapack/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.stromblex.vartapack.fabric.VartaPackFabricClient"
        ]
    },
    "depends": {
        "fabricloader": ">=0.16.0",
        "minecraft": "${fabric_minecraft_version_range}",
        "java": ">=21",
        "fabric-api": "*"
    },
    "accessWidener": "vartapack.accesswidener"
}
